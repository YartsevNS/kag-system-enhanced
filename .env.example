# FastAPI
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_DEBUG=False
FASTAPI_WORKERS=4

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=kag_documents

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Keycloak
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=kag
KEYCLOAK_CLIENT_ID=kag-api
KEYCLOAK_CLIENT_SECRET=change_me

# Keycloak DB (PostgreSQL для хранения конфигов)
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak_password
KC_DB_HOST=keycloak-db
KC_DB_PORT=5432
KC_DB_NAME=keycloak

# Casbin
CASBIN_MODEL_PATH=/app/src/auth/rbac_model.conf
CASBIN_POLICY_FILE=/app/src/auth/rbac_policy.csv

# OpenTelemetry
OTEL_SERVICE_NAME=kag-api
OTEL_EXPORTER_PROMETHEUS_PORT=9090

# ===========================================
# LLM конфигурация
# ===========================================

# Выбор бэкенда: vllm | ollama | openai | auto
LLM_BACKEND=ollama

# vLLM (локальный production сервер, 152-ФЗ compliant)
VLLM_BASE_URL=http://vllm:8000
VLLM_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2
VLLM_API_KEY=
VLLM_TIMEOUT=120.0
LLM_VLLM_PRIORITY=1
LLM_VLLM_ENABLED=false

# Ollama (удаленный сервер - основной)
OLLAMA_BASE_URL=${OLLAMA_BASE_URL:-http://host.docker.internal:11434}
OLLAMA_MODEL=mistral:7b
OLLAMA_TIMEOUT=120.0
OLLAMA_KEEP_ALIVE=30m
LLM_OLLAMA_PRIORITY=0
LLM_OLLAMA_ENABLED=true

# Embedding модели (Ollama)
EMBEDDING_BASE_URL=${OLLAMA_BASE_URL:-http://host.docker.internal:11434}
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_TIMEOUT=60.0
EMBEDDING_DIMENSIONS=768

# OpenAI API (fallback, не 152-ФЗ compliant!)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4
OPENAI_TIMEOUT=120.0
LLM_OPENAI_PRIORITY=2
LLM_OPENAI_ENABLED=false

# DashScope/Qwen API (опционально)
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-max

# Azure OpenAI (опционально)
AZURE_API_KEY=
AZURE_BASE_URL=
AZURE_MODEL=
AZURE_API_VERSION=2024-02-15-preview

# Общие настройки LLM
LLM_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1.0
LLM_HEALTH_CHECK_INTERVAL=60
LLM_AUTO_RECOVERY=true

# Безопасность
AES_GOST_KEY=
TLS_CERT_PATH=/etc/ssl/certs/kag.crt
TLS_KEY_PATH=/etc/ssl/private/kag.key

# Логи
LOG_LEVEL=INFO
LOG_FORMAT=json
